{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/videos/[category]/[id]",
      "regex": "^/videos/([^/]+?)/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPcategory": "nxtPcategory",
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/videos/(?<nxtPcategory>[^/]+?)/(?<nxtPid>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/videos",
      "regex": "^/videos(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/videos(?:/)?$"
    },
    {
      "page": "/videos/actualite",
      "regex": "^/videos/actualite(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/videos/actualite(?:/)?$"
    },
    {
      "page": "/videos/divertissement",
      "regex": "^/videos/divertissement(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/videos/divertissement(?:/)?$"
    },
    {
      "page": "/videos/documentaires",
      "regex": "^/videos/documentaires(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/videos/documentaires(?:/)?$"
    },
    {
      "page": "/videos/interviews",
      "regex": "^/videos/interviews(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/videos/interviews(?:/)?$"
    },
    {
      "page": "/videos/publicite",
      "regex": "^/videos/publicite(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/videos/publicite(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}